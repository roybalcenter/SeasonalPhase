# Load lubridate for easier date handling
# install.packages("lubridate")
library(lubridate)

transform_seasonal_phase <- function(dates) {
  # 1. Extract Day of the Year (1-366)
  # yday() is the R equivalent to Python's .dayofyear
  day_of_year <- yday(dates)
  
  # 2. Define the Anchor (Summer Solstice)
  # June 21 is typically day 172. 
  # Adjust this if your dataset is specific to a year where the 
  # solstice falls on the 20th or 22nd.
  solstice_day <- 172
  
  # 3. Calculate the Phase
  # We use 365.25 to account for leap year averages.
  # Formula: cos(2 * pi * (day - anchor) / year_length)
  # This results in +1 for Summer, -1 for Winter, and 0 for Equinoxes.
  seasonal_phase <- cos(2 * pi * (day_of_year - solstice_day) / 365.25)
  
  return(seasonal_phase)
}

# --- Example Usage ---
df <- data.frame(
  date = as.Date(c(
    '2024-06-21', # Summer Solstice (+1)
    '2024-12-21', # Winter Solstice (-1)
    '2024-03-20', # Spring Equinox (0)
    '2024-09-22', # Autumn Equinox (0)
    '2024-08-05'  # Mid-summer
  ))
)

# Apply the function
df$seasonal_phase <- transform_seasonal_phase(df$date)

# View results
print(df)
